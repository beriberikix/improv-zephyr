# Application configuration for the improv-wifi provisioning firmware.

mainmenu "Improv-WiFi provisioning"

menu "Improv-WiFi"

config IMPROV_SERIAL
	bool "Improv serial transport"
	default y
	depends on SERIAL
	select UART_INTERRUPT_DRIVEN
	help
	  Enable the improv-wifi serial transport. Listens on the console UART
	  (zephyr,console) for improv frames and is compatible with the
	  Web Serial installer at https://www.improv-wifi.com/serial/.

config IMPROV_BLE
	bool "Improv BLE (GATT) transport"
	default n
	depends on BT_PERIPHERAL
	help
	  Enable the improv-wifi BLE transport. Exposes the improv GATT service
	  and is compatible with the Web Bluetooth installer at
	  https://www.improv-wifi.com/ble/. Can be enabled alongside the serial
	  transport, but note that simultaneous Wi-Fi + BT on ESP32 can be
	  resource constrained.

config IMPROV_REDIRECT_URL
	string "Redirect URL returned after successful provisioning"
	default ""
	help
	  URL returned as the first string of the Wi-Fi settings RPC result; the
	  installer shows it as a "Next" link. If it contains the token "{ip}" the
	  device's assigned IPv4 address is substituted. If left empty, the device
	  falls back to "http://<ip>/". Set to a single space to suppress the URL.

config IMPROV_FIRMWARE_NAME
	string "Firmware name (device info)"
	default "improv-wifi-zephyr"

config IMPROV_FIRMWARE_VERSION
	string "Firmware version (device info)"
	default "0.1.0"

config IMPROV_DEVICE_NAME
	string "Human readable device name (device info)"
	default "Zephyr Improv"

endmenu

source "Kconfig.zephyr"
